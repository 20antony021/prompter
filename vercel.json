{
  "functions": {
    "src/app/api/prompts/process/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/prompts/[promptId]/status/route.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "src/app/api/analyze-mentions/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/check-subscriptions/route.ts": {
      "maxDuration": 300,
      "memory": 512
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 2 * * *"
    }
  ]
}
